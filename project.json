{
  "name": "Village Family Survey System",
  "version": "1.0.0",
  "description": "Complete offline-first Progressive Web App for village family survey data collection and analysis",
  "type": "pwa",
  "technology": "vanilla-js",
  "author": "Survey System",
  "license": "MIT",
  "keywords": [
    "survey",
    "offline",
    "pwa",
    "progressive-web-app",
    "village",
    "family",
    "data-collection",
    "census",
    "government",
    "indexeddb"
  ],
  "features": [
    "Complete offline support",
    "Authentication with SHA-256 hashing",
    "Village management",
    "House/family management",
    "Unlimited member management",
    "Aadhaar integration with image compression",
    "Advanced filtering system",
    "Global search",
    "Gender-based dashboard",
    "PDF generation",
    "Data export/import",
    "Dark/light theme toggle",
    "Responsive mobile-first design",
    "PWA installation support",
    "Service Worker caching"
  ],
  "dependencies": {
    "indexeddb": "native",
    "web-crypto-api": "native",
    "canvas-api": "native",
    "service-worker": "native"
  },
  "files": [
    "index.html",
    "login.html",
    "dashboard.html",
    "style.css",
    "app.js",
    "auth.js",
    "db.js",
    "pdf.js",
    "service-worker.js",
    "manifest.json",
    "icons/",
    "README.md",
    "QUICKSTART.md"
  ],
  "scripts": {
    "start": "Open index.html in browser",
    "deploy": "Deploy all files to web server",
    "backup": "Export data via Settings > Export Backup"
  },
  "browsers": {
    "chrome": "✅ Full support",
    "firefox": "✅ Full support",
    "safari": "✅ Full support",
    "edge": "✅ Full support",
    "mobile-chrome": "✅ Full support",
    "mobile-safari": "✅ Full support"
  },
  "database": {
    "type": "IndexedDB",
    "stores": [
      "villages",
      "houses",
      "members",
      "settings",
      "aadhaarImages"
    ]
  },
  "storage": {
    "type": "client-side-only",
    "location": "Browser IndexedDB",
    "privacy": "All data stored locally, never sent to server",
    "encryption": "SHA-256 password hashing"
  },
  "pwa": {
    "installable": true,
    "offline-capable": true,
    "service-worker": "service-worker.js",
    "manifest": "manifest.json",
    "icon-sizes": [72, 96, 128, 144, 152, 192, 384, 512]
  },
  "security": {
    "password-hashing": "SHA-256 (Web Crypto API)",
    "session-timeout": "30 minutes",
    "data-location": "Client-side only",
    "aadhaar-security": "Only last 4 digits stored",
    "encryption": "HTTPS recommended for deployment"
  },
  "performance": {
    "bundle-size": "~300KB",
    "load-time": "<2s with cache",
    "offline-mode": "100% functional",
    "memory-efficient": true
  },
  "responsive": {
    "mobile": true,
    "tablet": true,
    "desktop": true,
    "breakpoints": "mobile-first design"
  },
  "accessibility": {
    "semantic-html": true,
    "aria-labels": true,
    "keyboard-navigation": true,
    "color-contrast": "WCAG AA"
  },
  "setup": {
    "required": [
      "Modern web browser",
      "JavaScript enabled",
      "IndexedDB support"
    ],
    "optional": [
      "HTTPS (for PWA installation)",
      "Camera (for Aadhaar images)"
    ],
    "server": "None required"
  },
  "usage": {
    "first-time": "Click 'First Setup' to create password",
    "login": "Use created password",
    "data-entry": "Villages → Houses → Members",
    "offline": "All features work without internet"
  },
  "support": {
    "documentation": "README.md",
    "quick-start": "QUICKSTART.md",
    "troubleshooting": "README.md#troubleshooting"
  },
  "development": {
    "framework": "None (vanilla JavaScript)",
    "build-tool": "None required",
    "package-manager": "None required",
    "development-server": "Any HTTP server"
  },
